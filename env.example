# Copia este ficheiro para .env e preenche os valores

# A tua API Key do Smoobu (Settings > Developer > API Key)
SMOOBU_API_KEY=cola_aqui_a_tua_smoobu_api_key

# A tua API Key da Anthropic (console.anthropic.com)
ANTHROPIC_API_KEY=cola_aqui_a_tua_anthropic_api_key

# Porta do servidor (o Railway/Render define automaticamente)
PORT=3000
